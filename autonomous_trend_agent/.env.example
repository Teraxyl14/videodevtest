# Copy this to .env and fill in your values
# DO NOT commit .env to version control

# ── Gemini / Google ───────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL_NAME=gemini-1.5-flash

# ── YouTube Data API v3 (Phase 1 - Trend Discovery) ──────────────
# Get from: https://console.developers.google.com → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key-here

# ── Twitter/X (Phase 1 - Scraped, not official API) ──────────────
# Optional: official bearer token for elevated rate limits
# If not set, guest token scraping will be used
TWITTER_BEARER_TOKEN=

# ── Models ────────────────────────────────────────────────────────
QWEN_MODEL_PATH=Qwen/Qwen3-VL-8B-Instruct
HF_TOKEN=your-huggingface-token-here

# ── Infrastructure ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
